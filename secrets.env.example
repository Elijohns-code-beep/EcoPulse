# Copy this file to "secrets.env" (same folder) and fill in your real values.
# Do not commit secrets.env to git.

# Outlook app password (requires 2-step verification enabled on the account)
OUTLOOK_APP_PASSWORD=PASTE_APP_PASSWORD_HERE

# Optional overrides:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_DEBUG=1

